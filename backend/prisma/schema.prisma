generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  name             String?
  password         String?
  role             String    @default("PASAJERO")
  avatarUrl        String?
  expoPushToken    String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  verificationStatus String  @default("UNVERIFIED")
  githubId         String?   @unique
  bookings         Booking[] @relation("PassengerBookings")
  receivedMessages Message[] @relation("ReceivedMessages")
  sentMessages     Message[] @relation("SentMessages")
  reviewsReceived  Review[]  @relation("ReviewSubject")
  reviewsGiven     Review[]  @relation("ReviewAuthor")
  rides            Ride[]    @relation("DriverRides")
}

model Ride {
  id             String    @id @default(uuid())
  origin         String
  destination    String
  originLat      Float?
  originLng      Float?
  destLat        Float?
  destLng        Float?
  date           String
  availableSeats Int
  price          Float
  status         String    @default("ACTIVO")
  driverId       String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  bookings       Booking[]
  messages       Message[]
  reviews        Review[]  @relation("RideReviews")
  driver         User      @relation("DriverRides", fields: [driverId], references: [id])
}

model Booking {
  id            String   @id @default(uuid())
  seatsReserved Int
  status        String   @default("CONFIRMADA")
  passengerId   String
  rideId        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  amountPaid    Float?
  paymentRef    String?
  passenger     User     @relation("PassengerBookings", fields: [passengerId], references: [id])
  ride          Ride     @relation(fields: [rideId], references: [id])
}

model Message {
  id         String   @id @default(uuid())
  text       String
  senderId   String
  receiverId String
  rideId     String
  createdAt  DateTime @default(now())
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  ride       Ride     @relation(fields: [rideId], references: [id])
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
}

model Review {
  id         String   @id @default(uuid())
  rating     Int
  comment    String?
  reviewerId String
  revieweeId String
  rideId     String
  createdAt  DateTime @default(now())
  reviewee   User     @relation("ReviewSubject", fields: [revieweeId], references: [id])
  reviewer   User     @relation("ReviewAuthor", fields: [reviewerId], references: [id])
  ride       Ride     @relation("RideReviews", fields: [rideId], references: [id])
}
