generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String?
  githubId  String?  @unique
  role      String   @default("PASAJERO") // "CONDUCTOR" o "PASAJERO"
  avatarUrl String?
  expoPushToken String?
  idVerified    Boolean  @default(false)
  
  // Rides driven by this user
  rides     Ride[]   @relation("DriverRides")
  
  // Bookings made by this user (Passenger)
  bookings  Booking[] @relation("PassengerBookings")

  // Messages
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  
  // Reviews
  reviewsGiven     Review[]  @relation("ReviewAuthor")
  reviewsReceived  Review[]  @relation("ReviewSubject")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Ride {
  id             String   @id @default(uuid())
  origin         String
  destination    String
  originLat      Float?
  originLng      Float?
  destLat        Float?
  destLng        Float?
  date           String
  availableSeats Int
  price          Float
  status         String   @default("ACTIVO") // ACTIVO, COMPLETADO, CANCELADO
  
  // Relación con el Conductor
  driverId       String
  driver         User     @relation("DriverRides", fields: [driverId], references: [id])
  
  // Reservas asociadas a este viaje
  bookings       Booking[]
  
  // Mensajes asociados a este viaje
  messages       Message[]

  // Reseñas hechas durante/después este viaje
  reviews        Review[] @relation("RideReviews")

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Booking {
  id             String   @id @default(uuid())
  seatsReserved  Int
  status         String   @default("CONFIRMADA") // PENDIENTE, CONFIRMADA, CANCELADA
  
  // Pagos Stripe
  paymentRef     String?  // Reference ID de Stripe Payment Intent
  amountPaid     Float?   // Total en centavos o decimales

  passengerId    String
  passenger      User     @relation("PassengerBookings", fields: [passengerId], references: [id])
  
  rideId         String
  ride           Ride     @relation(fields: [rideId], references: [id])
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Message {
  id             String   @id @default(uuid())
  text           String
  
  senderId       String
  sender         User     @relation("SentMessages", fields: [senderId], references: [id])

  receiverId     String
  receiver       User     @relation("ReceivedMessages", fields: [receiverId], references: [id])

  rideId         String
  ride           Ride     @relation(fields: [rideId], references: [id])

  createdAt      DateTime @default(now())
}

model Review {
  id             String   @id @default(uuid())
  rating         Int
  comment        String?
  
  reviewerId     String
  reviewer       User     @relation("ReviewAuthor", fields: [reviewerId], references: [id])
  
  revieweeId     String
  reviewee       User     @relation("ReviewSubject", fields: [revieweeId], references: [id])
  
  rideId         String
  ride           Ride     @relation("RideReviews", fields: [rideId], references: [id])
  
  createdAt      DateTime @default(now())
}
